# Copy to .env and fill in real values. The script reads trios of
# <PROVIDER>_API_KEY / <PROVIDER>_BASE_URL / <PROVIDER>_MODEL (PROVIDER uppercased),
# picked with --provider. base_url and model have built-in defaults per provider,
# so for known providers you usually only need the API key.

# DashScope / Bailian — OpenAI-compatible mode.
# DASHSCOPE_PLAN can be:
#   payg-beijing | payg-singapore | payg-us | token-plan | coding-plan
# Plan-specific API keys win over DASHSCOPE_API_KEY when present.
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=
DASHSCOPE_BASE_URL=
DASHSCOPE_PLAN=payg-beijing
DASHSCOPE_WORKSPACE_ID=
DASHSCOPE_TOKEN_PLAN_API_KEY=
DASHSCOPE_TOKEN_PLAN_MODEL=
DASHSCOPE_TOKEN_PLAN_BASE_URL=
DASHSCOPE_CODING_PLAN_API_KEY=
DASHSCOPE_CODING_PLAN_MODEL=
DASHSCOPE_CODING_PLAN_BASE_URL=

# DeepSeek
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL and DEEPSEEK_MODEL have built-in defaults

# Moonshot / Kimi
MOONSHOT_API_KEY=

# Zhipu / GLM (bigmodel.cn)
ZHIPU_API_KEY=

# SiliconFlow — model name is owner/model, e.g. Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_API_KEY=

# OpenRouter — model name is owner/model, e.g. openai/gpt-4o-mini
OPENROUTER_API_KEY=

# OpenAI official
OPENAI_API_KEY=

# Local Ollama — API key is ignored; run `ollama serve` and pass any dummy
# OLLAMA_API_KEY=dummy
